<form method="post" action="{{ form_action }}">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token }}">
    
        <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="public_key" class="form-label">
                            {{ __('Clé publique', 'watchman') }}
                        </label>
                        <input type="text" 
                               name="public_key" 
                               id="public_key" 
                               class="cms_watchman_input"
                               value="{{ config.public_key|default('') }}">
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="secret_key" class="form-label">
                            {{ __('Clé secrète', 'watchman') }}
                        </label>
                        <input type="password" 
                               name="secret_key" 
                               id="secret_key" 
                               class="cms_watchman_input"
                               value="{{ config.secret_key|default('') }}">
                    </div>
                </div>
            </div>
        

        {# <h3 class="card-title">{{ __('Configuration des tâches cron', 'watchman') }}</h3> #}
        <div class="">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="cron_enabled" class="form-label">
                            {{ __('Activer les tâches cron', 'watchman') }}
                        </label>
                        <select name="cron_enabled" id="cron_enabled" class="cms_watchman_input cms_watchman_select">
                            <option value="1" {{ config.cron_enabled == '1' ? 'selected' : '' }}>
                                {{ __('Activé', 'watchman') }}
                            </option>
                            <option value="0" {{ config.cron_enabled == '0' ? 'selected' : '' }}>
                                {{ __('Désactivé', 'watchman') }}
                            </option>
                        </select>
                        <div class="form-text">
                            {{ __('Active ou désactive l\'exécution automatique des tâches en arrière-plan', 'watchman') }}
                        </div>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="cron_frequency" class="form-label">
                            {{ __('Fréquence d\'exécution (secondes)', 'watchman') }}
                        </label>
                        <select name="cron_frequency" id="cron_frequency" class="cms_watchman_input cms_watchman_select">
                            <option value="60" {{ config.cron_frequency == '60' ? 'selected' : '' }}>
                                {{ __('1 minute', 'watchman') }}
                            </option>
                            <option value="300" {{ config.cron_frequency == '300' ? 'selected' : '' }}>
                                {{ __('5 minutes', 'watchman') }}
                            </option>
                            <option value="900" {{ config.cron_frequency == '900' ? 'selected' : '' }}>
                                {{ __('15 minutes', 'watchman') }}
                            </option>
                            <option value="1800" {{ config.cron_frequency == '1800' ? 'selected' : '' }}>
                                {{ __('30 minutes', 'watchman') }}
                            </option>
                            <option value="3600" {{ config.cron_frequency == '3600' ? 'selected' : '' }}>
                                {{ __('1 heure', 'watchman') }}
                            </option>
                            <option value="7200" {{ config.cron_frequency == '7200' ? 'selected' : '' }}>
                                {{ __('2 heures', 'watchman') }}
                            </option>
                            <option value="21600" {{ config.cron_frequency == '21600' ? 'selected' : '' }}>
                                {{ __('6 heures', 'watchman') }}
                            </option>
                            <option value="43200" {{ config.cron_frequency == '43200' ? 'selected' : '' }}>
                                {{ __('12 heures', 'watchman') }}
                            </option>
                            <option value="86400" {{ config.cron_frequency == '86400' ? 'selected' : '' }}>
                                {{ __('24 heures', 'watchman') }}
                            </option>
                        </select>
                        <div class="form-text">
                            {{ __('Détermine la fréquence à laquelle les tâches cron seront exécutées', 'watchman') }}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">{{ __('Statut actuel', 'watchman') }}</label>
                        <div class="form-control-plaintext">
                            {% set status_class = config.cron_status == 'running' ? 'text-success' : 'text-secondary' %}
                            <span class="{{ status_class }}">
                                {% if config.cron_status == 'running' %}
                                    <i class="fas fa-play-circle me-1"></i>{{ __('En cours d\'exécution', 'watchman') }}
                                {% elseif config.cron_status == 'stopped' %}
                                    <i class="fas fa-stop-circle me-1"></i>{{ __('Arrêté', 'watchman') }}
                                {% else %}
                                    <i class="fas fa-question-circle me-1"></i>{{ __('Inconnu', 'watchman') }}
                                {% endif %}
                            </span>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">{{ __('Dernière exécution', 'watchman') }}</label>
                        <div class="form-control-plaintext">
                            {% if config.cron_last_run %}
                                <span class="text-info">
                                    <i class="fas fa-clock me-1"></i>
                                    {{ config.cron_last_run|date('d/m/Y H:i:s') }}
                                </span>
                            {% else %}
                                <span class="text-muted">
                                    <i class="fas fa-minus-circle me-1"></i>
                                    {{ __('Jamais exécuté', 'watchman') }}
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                <strong>{{ __('Information', 'watchman') }}:</strong>
                {{ __('Les tâches cron permettent d\'exécuter automatiquement des actions en arrière-plan selon la fréquence définie. Assurez-vous que le plugin est actif pour que les tâches cron fonctionnent.', 'watchman') }}
            </div>
        </div>
    
    
    <div class="d-flex justify-content-end mt-3">
        <button type="submit" name="update" class="btn btn-primary">
            <i class="fas fa-save me-1"></i>{{ __('Sauvegarder', 'watchman') }}
        </button>
    </div>
</form>