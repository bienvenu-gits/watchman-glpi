<script>
// ═══════════════════════════════════════════
//  VARIABLES
// ═══════════════════════════════════════════
const WATCHMAN_SELECT_URL = '{{ base_url }}/plugins/watchman/ajax/computer_select.php';
let modal_computers      = [];
let subscription_quota   = 0;

// ═══════════════════════════════════════════
//  CHARGEMENT INITIAL
// ═══════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => loadSelectedMachines());

async function loadSelectedMachines() {
    try {
        const resp = await fetch(`${WATCHMAN_SELECT_URL}?action=get_all_computers`);
        const data = await resp.json();
        if (!data.success) return;

        const selected = data.computers.filter(c => c.is_selected);
        const tbody = document.getElementById('selected_machines_body');

        if (selected.length === 0) {
            tbody.innerHTML = `<tr><td colspan="4" style="text-align:center; padding:30px; color:#999;">
                <i class="fas fa-desktop" style="font-size:24px; margin-bottom:8px; display:block;"></i>
                Aucune machine sélectionnée.<br>
                <button class="cms_watchman_btn cms_watchman_btn-primary btn-sm" style="margin-top:12px;" onclick="openMachineModal()">
                    + Ajouter des machines
                </button>
            </td></tr>`;
            return;
        }

        tbody.innerHTML = selected.map(c => `
            <tr>
                <td><strong>${c.name}</strong></td>
                <td><span class="cms_watchman_badge cms_watchman_badge-${c.sync_status === 'success' ? 'success' : c.sync_status === 'error' ? 'danger' : 'warning'}">
                    ${c.sync_status === 'success' ? 'Synchronisé' : c.sync_status === 'error' ? 'Erreur' : 'En attente'}
                </span></td>
                <td>${c.last_sync_date ? new Date(c.last_sync_date).toLocaleDateString('fr-FR') : '<span style="color:#999">Jamais</span>'}</td>
                <td>
                    <button class="cms_watchman_btn cms_watchman_btn-outline btn-sm" onclick="removeMachine(${c.id})" title="Retirer">
                        <i class="fas fa-times"></i>
                    </button>
                </td>
            </tr>
        `).join('');
    } catch(e) {
        console.error(e);
    }
}

// ═══════════════════════════════════════════
//  MODAL
// ═══════════════════════════════════════════
async function openMachineModal() {
    document.getElementById('machine_modal').style.display = 'flex';
    document.getElementById('modal_search').value = '';

    const [compResp, subResp] = await Promise.all([
        fetch(`${WATCHMAN_SELECT_URL}?action=get_all_computers`),
        fetch(`${WATCHMAN_SELECT_URL}?action=get_subscription`)
    ]);
    const compData = await compResp.json();
    const subData  = await subResp.json();

    subscription_quota = (subData.success && subData.quantity > 0) ? subData.quantity : 0;

    if (compData.success) {
        modal_computers = compData.computers;
        renderModalTable(modal_computers);
    }
}

function closeMachineModal() {
    document.getElementById('machine_modal').style.display = 'none';
}

// Fermer en cliquant hors du modal
document.getElementById('machine_modal')?.addEventListener('click', function(e) {
    if (e.target === this) closeMachineModal();
});

function renderModalTable(computers) {
    const tbody = document.getElementById('modal_machines_body');

    if (computers.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding:20px; color:#999;">Aucune machine trouvée</td></tr>';
        updateModalCount();
        return;
    }

    tbody.innerHTML = computers.map(c => `
        <tr>
            <td><input type="checkbox" class="modal_checkbox" value="${c.id}"
                       ${c.is_selected ? 'checked' : ''} onchange="updateModalCount()"></td>
            <td><strong>${c.name}</strong></td>
            <td><span class="cms_watchman_badge cms_watchman_badge-${c.sync_status === 'success' ? 'success' : 'warning'}">
                ${c.sync_status === 'success' ? 'Sync' : 'En attente'}
            </span></td>
            <td style="font-size:12px; color:#666;">
                ${c.last_sync_date ? new Date(c.last_sync_date).toLocaleDateString('fr-FR') : 'Jamais'}
            </td>
        </tr>
    `).join('');

    updateModalCount();
}

function filterModalTable(query) {
    const q = query.toLowerCase();
    renderModalTable(modal_computers.filter(c => c.name.toLowerCase().includes(q)));
}

function modalSelectAll()  { document.querySelectorAll('.modal_checkbox').forEach(c => c.checked = true);  updateModalCount(); }
function modalSelectNone() { document.querySelectorAll('.modal_checkbox').forEach(c => c.checked = false); updateModalCount(); }
function modalToggleAll(master) { document.querySelectorAll('.modal_checkbox').forEach(c => c.checked = master.checked); updateModalCount(); }

function updateModalCount() {
    const checked = document.querySelectorAll('.modal_checkbox:checked').length;
    const total   = document.querySelectorAll('.modal_checkbox').length;
    document.getElementById('modal_count').textContent = `${checked} / ${total} sélectionnée(s)`;
    updateQuotaBar(checked);
}

function updateQuotaBar(checked) {
    const container = document.getElementById('modal_quota_bar_container');
    const banner    = document.getElementById('modal_quota_banner');
    if (!container) return;

    if (!subscription_quota) {
        container.style.display = 'none';
        if (banner) banner.style.display = 'none';
        return;
    }

    container.style.display = 'block';

    const pct  = Math.min(100, Math.round((checked / subscription_quota) * 100));
    const rem  = subscription_quota - checked;
    const fill = document.getElementById('modal_quota_fill');
    document.getElementById('modal_quota_label').textContent     = `${checked} / ${subscription_quota} machines sélectionnées`;
    document.getElementById('modal_quota_remaining').textContent = rem > 0 ? `${rem} restante(s)` : 'Limite atteinte';

    fill.style.width = pct + '%';

    if (pct >= 100) {
        fill.style.background = '#dc3545';
        if (banner) banner.style.display = 'block';
        document.querySelectorAll('.modal_checkbox:not(:checked)').forEach(cb => {
            cb.disabled = true;
            cb.title    = 'Limite atteinte — désélectionnez d\'abord certaines machines';
        });
    } else {
        fill.style.background = pct >= 80 ? '#ffc107' : '#28a745';
        if (banner) banner.style.display = 'none';
        document.querySelectorAll('.modal_checkbox:not(:checked)').forEach(cb => {
            cb.disabled = false;
            cb.title    = '';
        });
    }
}

async function saveModalSelection() {
    const selected_ids = [...document.querySelectorAll('.modal_checkbox:checked')].map(c => parseInt(c.value));

    const resp = await fetch(`${WATCHMAN_SELECT_URL}?action=save_selection`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ selected_ids })
    });
    const data = await resp.json();

    if (data.success) {
        closeMachineModal();
        loadSelectedMachines();
        // notification
        const toast = document.createElement('div');
        toast.className = 'alert alert-success alert-dismissible fade show position-fixed';
        toast.style.cssText = 'top:20px; right:20px; z-index:99999; min-width:300px;';
        toast.innerHTML = `${data.message} <button type="button" class="btn-close" onclick="this.parentNode.remove()"></button>`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    }
}

async function removeMachine(computer_id) {
    const confirmed = await showRemovalWarning();
    if (!confirmed) return;

    const resp = await fetch(`${WATCHMAN_SELECT_URL}?action=get_all_computers`);
    const data = await resp.json();
    if (!data.success) return;

    const selected_ids = data.computers
        .filter(c => c.is_selected && c.id !== computer_id)
        .map(c => c.id);

    const resp2 = await fetch(`${WATCHMAN_SELECT_URL}?action=save_selection`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ selected_ids })
    });

    const data2 = await resp2.json();
    if (data2.success) loadSelectedMachines();
}

function showRemovalWarning() {
    return new Promise(resolve => {
        const overlay = document.createElement('div');
        overlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.55); z-index:99999; display:flex; align-items:center; justify-content:center;';
        overlay.innerHTML = `
            <div style="background:#fff; border-radius:12px; max-width:480px; width:90%; padding:28px; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
                <div style="display:flex; align-items:flex-start; gap:14px; margin-bottom:20px;">
                    <div style="background:#fff3cd; border-radius:50%; width:46px; height:46px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <i class="fas fa-exclamation-triangle" style="color:#e67e22; font-size:18px;"></i>
                    </div>
                    <div>
                        <h4 style="margin:0 0 8px 0; font-size:16px; font-weight:600;">Information de sécurité</h4>
                        <p style="margin:0; font-size:14px; color:#495057; line-height:1.6;">
                            Cette action retire la machine de la liste de synchronisation <strong>dans ce plugin uniquement</strong>.
                            La machine reste présente dans votre dashboard Watchman.
                        </p>
                        <p style="margin:10px 0 0 0; font-size:14px; color:#495057; line-height:1.6;">
                            Pour la supprimer définitivement, connectez-vous sur <strong>votre compte watchman.bj</strong>
                            et supprimez-la depuis votre dashboard. La suppression directe dans le plugin n'est pas
                            disponible pour des raisons de sécurité.
                        </p>
                    </div>
                </div>
                <div style="display:flex; justify-content:flex-end; gap:10px;">
                    <button id="warn_cancel" class="cms_watchman_btn cms_watchman_btn-outline">Annuler</button>
                    <button id="warn_confirm" class="cms_watchman_btn" style="background:#dc3545; color:#fff; border-color:#dc3545;">
                        Retirer du plugin
                    </button>
                </div>
            </div>
        `;
        document.body.appendChild(overlay);
        overlay.querySelector('#warn_cancel').onclick  = () => { overlay.remove(); resolve(false); };
        overlay.querySelector('#warn_confirm').onclick = () => { overlay.remove(); resolve(true); };
    });
}
</script>
