<script>
function toggleSwitch(track) {
    const label  = track.closest('label');
    const hidden   = label.querySelector('input[type=hidden]');
    const checkbox = label.querySelector('input[type=checkbox]');
    const knob     = track.querySelector('span');
    const text     = label.querySelector('span:last-child');

    const nowOn = !checkbox.checked;
    checkbox.checked = nowOn;
    hidden.value = nowOn ? '1' : '0';
    track.style.background = nowOn ? '#2d6a4f' : '#ced4da';
    knob.style.left = nowOn ? '23px' : '3px';

    const labels = {
        sync_alerts_enabled:     [' Désactivée', ' Activée'],
        show_alerts_tab:         [' Masqué',     ' Visible'],
        ticket_creation_enabled: [' Désactivée', ' Activée'],
    };
    const name = checkbox.name;
    if (labels[name]) text.textContent = nowOn ? labels[name][1] : labels[name][0];
}
</script>


