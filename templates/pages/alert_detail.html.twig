{# Template de base pour plugin GLPI - sans structure HTML complète #}
{# Ce template s'intègre dans la structure HTML existante de GLPI #}

{# CSS spécifique au plugin #}
	{% block plugin_styles %}
	<link rel="stylesheet" type="text/css" href="{{ base_url }}/plugins/watchman/assets/css/icons.css"> <link rel="stylesheet" type="text/css" href="{{ base_url }}/plugins/watchman/assets/css/tailwind.css">
	<link
	rel="stylesheet" type="text/css" href="{{ base_url }}/plugins/watchman/assets/css/cms_watchman.css">
	{# Flatpickr pour le date range picker #}
	<link
	rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
	{# Font Awesome pour les icônes #}
	<link
	rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
	{# Material Design Icons #}
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/MaterialDesign-Webfont/7.0.96/css/materialdesignicons.min.css">
{% endblock %}

{# Token CSRF pour les requêtes AJAX #}
<input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token }}">

<div
	class="plugin-container">
	{# Navbar du plugin #}
	{% block navbar %}
		{% include '@watchman/components/navbar.html.twig' %}
	{% endblock %}

	<div data-layout-mode="light" class="cms_watchman">
		<div class="cms_watchman_container cms_watchman_page_content">

			<div class="cms_watchman_alert_detail_title">
				<a href="?page=cms_watchman_alert">
					<i class="fas fa-arrow-left"></i>
				</a>
				<span>{{ __("Détails de l'alerte", "watchman") }}</span>
			</div>

			{# Indicateur de chargement #}
			<div class="cms_watchman_content_loading">
				<div class="d-flex justify-content-center align-items-center" style="height: 200px;">
					<div class="spinner-border text-primary" role="status">
						<span class="sr-only">{{ __("Chargement...", "watchman") }}</span>
					</div>
					<span class="ml-3">{{ __("Chargement des détails de l'alerte...", "watchman") }}</span>
				</div>
			</div>

			{# État vide #}
			<div class="cms_watchman_content_empty hidden">
				<div class="text-center" style="padding: 60px 20px;">
					<i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
					<h1 class="heading">{{ __("Alerte introuvable", "watchman") }}</h1>
					<p class="description">{{ __("L'alerte demandée n'a pas été trouvée ou n'existe plus.", "watchman") }}</p>
					<a href="?page=cms_watchman_alert" class="btn btn-primary">
						<i class="fas fa-arrow-left"></i>
						{{ __("Retour aux alertes", "watchman") }}
					</a>
				</div>
			</div>

			{# Contenu principal #}
			<div
				class="cms_watchman_content_main_body hidden">
				{# En-tête de l'alerte #}
				<div class="cms_watchman_alert_detail_header">
					<div class="cms_watchman_alert_detail_header_text">
						<h1>{{ __("Informations sur l'alerte", "watchman") }}</h1>
						<p>{{ __("Détails complets de la vulnérabilité détectée", "watchman") }}</p>
					</div>
					<div class="cms_watchman_alert_detail_header_button">
						<button class="cms_watchman_btn cms_watchman_btn-light" id="cms_watchman_alert_patch_btn">
							<i class="mdi mdi-update"></i>
							<span>{{ __("Patch", "watchman") }}</span>
						</button>
					</div>
				</div>

				{# Contenu de l'alerte #}
				<div
					class="cms_watchman_alert_detail_row">
					{# Colonne des détails #}
					<div
						class="cms_watchman_alert_detail_row_detail">
						{# Description #}
						<div class="cms_watchman_alert_detail_card cms_watchman_alert_detail_description">
							<h1 id="cms_watchman_alert_cve_id">{{ __("Chargement...", "watchman") }}</h1>
							<h2>{{ __("Description", "watchman") }}</h2>
							<p id="cms_watchman_alert_description">{{ __("Chargement de la description...", "watchman") }}</p>
						</div>

						{# Références #}
						<div class="cms_watchman_alert_detail_card cms_watchman_alert_detail_description">
							<h2>{{ __("Références", "watchman") }}</h2>
							<div class="cms_watchman_table_container">
								<table class="cms_watchman_table" id="cms_watchman_alert_references_table">
									<thead>
										<tr>
											<th>{{ __("Nom", "watchman") }}</th>
											<th>{{ __("URL", "watchman") }}</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td colspan="2" class="text-center">{{ __("Chargement...", "watchman") }}</td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>

						{# Produits vulnérables #}
						<div class="cms_watchman_alert_detail_card cms_watchman_alert_detail_description">
							<h2>{{ __("Produits vulnérables", "watchman") }}</h2>
							<div class="cms_watchman_table_container">
								<table class="cms_watchman_table" id="cms_watchman_alert_product_table">
									<thead>
										<tr>
											<th>{{ __("Fournisseur", "watchman") }}</th>
											<th>{{ __("Nom du produit", "watchman") }}</th>
											<th>{{ __("Version", "watchman") }}</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td colspan="3" class="text-center">{{ __("Chargement...", "watchman") }}</td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>

						{# Stack vulnérable #}
						<div class="cms_watchman_alert_detail_card cms_watchman_alert_detail_description">
							<h2>{{ __("Actif vulnérable", "watchman") }}</h2>
							<div class="cms_watchman_table_container">
								<table class="cms_watchman_table" id="cms_watchman_alert_vulnerable_stack">
									<thead>
										<tr>
											<th>{{ __("Nom", "watchman") }}</th>
											<th>{{ __("Version", "watchman") }}</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td colspan="2" class="text-center">{{ __("Chargement...", "watchman") }}</td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>

						{# Informations temporelles #}
						<div class="cms_watchman_alert_detail_card cms_watchman_alert_detail_description">
							<h2>{{ __("Plus d'informations", "watchman") }}</h2>
							<div class="cms_watchman_alert_information_flex">
								<h1>{{ __("Publié", "watchman") }}</h1>
								<span id="cms_watchman_alert_published">{{ __("Chargement...", "watchman") }}</span>
							</div>
							<div class="cms_watchman_alert_information_flex">
								<h1>{{ __("Modifié", "watchman") }}</h1>
								<span id="cms_watchman_alert_updated">{{ __("Chargement...", "watchman") }}</span>
							</div>
						</div>
					</div>

					{# Colonne des statistiques #}
					<div
						class="cms_watchman_alert_detail_row_stats">
						{# CVE Assigneur #}
						<div class="cms_watchman_cve">
							<h1>{{ __("CVE assigneur", "watchman") }}</h1>
							<p id="cms_watchman_alert_cve_assigner">{{ __("Chargement...", "watchman") }}</p>
						</div>

						{# Score de sévérité #}
						<div class="cms_watchman_severity_score">
							<h1>{{ __("Score", "watchman") }}</h1>
							<h2 id="cms_watchman_alert_score">{{ __("N/A", "watchman") }}</h2>
							<div class="cms_watchman_severity_name">
								<h1 id="cms_watchman_alert_severity_value">{{ __("Chargement...", "watchman") }}</h1>
								<h1 id="cms_watchman_alert_attack_vector">{{ __("Vecteur d'attaque: N/A", "watchman") }}</h1>
							</div>
						</div>

						{# Barres de progression #}
						<div class="cms_watchman_alert_progressbar" id="cms_watchman_alert_severity_progressbar">
							<div class="cms_watchman_alert_progressbar_label">
								<span class="label">{{ __("Sévérité", "watchman") }}</span>
								<span class="value">{{ __("N/A", "watchman") }}</span>
							</div>
							<div class="cms_watchman_progressbar_container">
								<div class="cms_watchman_progressbar">
									<div class="cms_watchman_progressbar_fill" style="width: 0%;"></div>
								</div>
							</div>
						</div>

						<div class="cms_watchman_alert_progressbar" id="cms_watchman_alert_complexity_attack_progressbar">
							<div class="cms_watchman_alert_progressbar_label">
								<span class="label">{{ __("Complexité de l'attaque", "watchman") }}</span>
								<span class="value">{{ __("N/A", "watchman") }}</span>
							</div>
							<div class="cms_watchman_progressbar_container">
								<div class="cms_watchman_progressbar">
									<div class="cms_watchman_progressbar_fill" style="width: 0%;"></div>
								</div>
							</div>
						</div>

						<div class="cms_watchman_alert_progressbar" id="cms_watchman_alert_privileges_required_progressbar">
							<div class="cms_watchman_alert_progressbar_label">
								<span class="label">{{ __("Privilèges requis", "watchman") }}</span>
								<span class="value">{{ __("N/A", "watchman") }}</span>
							</div>
							<div class="cms_watchman_progressbar_container">
								<div class="cms_watchman_progressbar">
									<div class="cms_watchman_progressbar_fill" style="width: 0%;"></div>
								</div>
							</div>
						</div>

						<div class="cms_watchman_alert_progressbar" id="cms_watchman_alert_user_interaction_progressbar">
							<div class="cms_watchman_alert_progressbar_label">
								<span class="label">{{ __("Interaction avec l'utilisateur", "watchman") }}</span>
								<span class="value">{{ __("N/A", "watchman") }}</span>
							</div>
							<div class="cms_watchman_progressbar_container">
								<div class="cms_watchman_progressbar">
									<div class="cms_watchman_progressbar_fill" style="width: 0%;"></div>
								</div>
							</div>
						</div>

						<div class="cms_watchman_alert_progressbar" id="cms_watchman_alert_confidentiality_impact_progressbar">
							<div class="cms_watchman_alert_progressbar_label">
								<span class="label">{{ __("Impact sur la confidentialité", "watchman") }}</span>
								<span class="value">{{ __("N/A", "watchman") }}</span>
							</div>
							<div class="cms_watchman_progressbar_container">
								<div class="cms_watchman_progressbar">
									<div class="cms_watchman_progressbar_fill" style="width: 0%;"></div>
								</div>
							</div>
						</div>

						<div class="cms_watchman_alert_progressbar" id="cms_watchman_alert_integrity_impact_progressbar">
							<div class="cms_watchman_alert_progressbar_label">
								<span class="label">{{ __("Impact sur l'intégrité", "watchman") }}</span>
								<span class="value">{{ __("N/A", "watchman") }}</span>
							</div>
							<div class="cms_watchman_progressbar_container">
								<div class="cms_watchman_progressbar">
									<div class="cms_watchman_progressbar_fill" style="width: 0%;"></div>
								</div>
							</div>
						</div>

						<div class="cms_watchman_alert_progressbar" id="cms_watchman_alert_availability_impact_progressbar">
							<div class="cms_watchman_alert_progressbar_label">
								<span class="label">{{ __("Impact sur la disponibilité", "watchman") }}</span>
								<span class="value">{{ __("N/A", "watchman") }}</span>
							</div>
							<div class="cms_watchman_progressbar_container">
								<div class="cms_watchman_progressbar">
									<div class="cms_watchman_progressbar_fill" style="width: 0%;"></div>
								</div>
							</div>
						</div>
						<div class="cms_watchman_cve">
							<h1>{{ __("Ticket", "watchman") }}</h1>
							<button class="cms_watchman_btn cms_watchman_btn-light" id="cms_watchman_alert_ticket_btn">
								<span>{{ __("Voir ticket", "watchman") }}</span>
							</button>
						</div>
					</div>

					{# Ticket #}

				</div>
			</div>
		</div>
	</div>

	{# Footer optionnel #}
	{% block footer %}
		{% include '@watchman/components/footer.html.twig' %}
	{% endblock %}
</div>

{# JavaScript spécifique au plugin #}
{% block plugin_scripts %}
	{# jQuery si pas déjà inclus par GLPI #}
	<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

	{# Flatpickr pour le date range picker #}
	<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
	<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

	{# Bootstrap JS pour les dropdowns #}
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.bundle.min.js"></script>

	<script>
		// Configuration globale pour le plugin Watchman
window.WATCHMAN_CONFIG = {
ajaxUrl: '{{ path("plugins/watchman/ajax/alert_detail.php") }}',
csrfToken: '{{ csrf_token }}',
translations: {
confirmDelete: '{{ __("Êtes-vous sûr de vouloir supprimer cette alerte ?", "watchman") }}',
confirmBulkDelete: '{{ __("Êtes-vous sûr de vouloir supprimer les alertes sélectionnées ?", "watchman") }}',
confirmMarkPatched: '{{ __("Marquer cette alerte comme corrigée ?", "watchman") }}',
confirmBulkPatched: '{{ __("Marquer les alertes sélectionnées comme corrigées ?", "watchman") }}',
loading: '{{ __("Chargement...", "watchman") }}',
error: '{{ __("Erreur", "watchman") }}',
success: '{{ __("Succès", "watchman") }}',
noData: '{{ __("Aucune donnée disponible", "watchman") }}',
alertNotFound: '{{ __("Alerte introuvable", "watchman") }}',
patchSuccess: '{{ __("Statut de patch mis à jour avec succès", "watchman") }}',
patchError: '{{ __("Erreur lors de la mise à jour du statut", "watchman") }}'
}
};

$(document).ready(function () {
console.log('Plugin  {{ plugin_name|default("Watchman") }}Alert Detail initialisé');

// Configuration de Flatpickr en français
if (typeof flatpickr !== 'undefined') {
flatpickr.localize(flatpickr.l10ns.fr);
}
});
	</script>

	{# Script principal pour les détails d'alerte #}
	<script src="{{ base_url }}/plugins/watchman/assets/js/alert_detail.js"></script>
{% endblock %}
