{# Template de base pour plugin GLPI - sans structure HTML complète #}
{# Ce template s'intègre dans la structure HTML existante de GLPI #}

{# CSS spécifique au plugin #}
{% block plugin_styles %}
<link rel="stylesheet" type="text/css" href="{{ base_url }}/plugins/watchman/assets/css/icons.css"> <link rel="stylesheet" type="text/css" href="{{ base_url }}/plugins/watchman/assets/css/tailwind.css">
<link
rel="stylesheet" type="text/css" href="{{ base_url }}/plugins/watchman/assets/css/cms_watchman.css">
{# Flatpickr pour le date range picker #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
	.computer-name {
		max-width: 300px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.cms_watchman_content_loading {
		text-align: center;
		padding: 50px;
	}
	.cms_watchman_loading {
		display: inline-block;
		width: 40px;
		height: 40px;
		border: 3px solid #f3f3f3;
		border-top: 3px solid #3498db;
		border-radius: 50%;
		animation: spin 1s linear infinite;
	}
	@keyframes spin {
		0% {
			transform: rotate(0deg);
		}
		100% {
			transform: rotate(360deg);
		}
	}
	.cms_watchman_content_empty {
		text-align: center;
		padding: 50px;
		color: #666;
	}
	.cms_watchman_content_empty h1 {
		font-size: 24px;
		margin-bottom: 10px;
		color: #333;
	}
	.cms_watchman_content_empty .description {
		font-size: 16px;
		color: #666;
	}
	.dropdown-menu {
		min-width: 150px;
	}
	.dropdown-item {
		padding: 8px 15px;
		cursor: pointer;
	}
	.dropdown-item:hover {
		background-color: #f8f9fa;
	}
	.sync-status-badge {
		font-size: 0.75rem;
		padding: 0.25rem 0.5rem;
	}
</style>
{% endblock %}

