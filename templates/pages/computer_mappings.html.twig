{# Scripts JavaScript #}
{% block plugin_scripts %}
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>

// ═══ MODAL SYNCHRONISATION ═══

// ═══════════════════════════════════════════
//  VARIABLES
// ═══════════════════════════════════════════
const WATCHMAN_SELECT_URL = '{{ base_url }}/plugins/watchman/ajax/computer_select.php';
let modal_computers      = [];
let subscription_quota   = 0;



// ═══════════════════════════════════════════
//  CHARGEMENT INITIAL
// ═══════════════════════════════════════════
function openSyncModal(computers) {
    modal_computers = computers || [];
    document.getElementById('machine_modal').style.display = 'flex';
    document.getElementById('modal_search').value = '';
    renderSyncModalTable(modal_computers);
}

// ═══════════════════════════════════════════
//  MODAL
// ═══════════════════════════════════════════
async function openMachineModal() {
    document.getElementById('machine_modal').style.display = 'flex';
    document.getElementById('modal_search').value = '';

    const [compResp, subResp] = await Promise.all([
        fetch(`${WATCHMAN_SELECT_URL}?action=get_all_computers`),
        fetch(`${WATCHMAN_SELECT_URL}?action=get_subscription`)
    ]);
    const compData = await compResp.json();
    const subData  = await subResp.json();

    subscription_quota = (subData.success && subData.quantity > 0) ? subData.quantity : 0;

    if (compData.success) {
        modal_computers = compData.computers;
        renderModalTable(modal_computers);
    }
}

function closeMachineModal() {
    document.getElementById('machine_modal').style.display = 'none';
}

// Fermer en cliquant hors du modal
document.getElementById('machine_modal')?.addEventListener('click', function(e) {
    if (e.target === this) closeMachineModal();
});

function renderModalTable(computers) {
    const tbody = document.getElementById('modal_machines_body');

    if (computers.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding:20px; color:#999;">Aucune machine trouvée</td></tr>';
        updateModalCount();
        return;
    }

    tbody.innerHTML = computers.map(c => `
        <tr>
            <td><input type="checkbox" class="modal_checkbox" value="${c.id}"
                       ${c.is_selected ? 'checked' : ''} onchange="updateModalCount()"></td>
            <td><strong>${c.name}</strong></td>
            <td><span class="cms_watchman_badge cms_watchman_badge-${c.sync_status === 'success' ? 'success' : 'warning'}">
                ${c.sync_status === 'success' ? 'Sync' : 'En attente'}
            </span></td>
            <td style="font-size:12px; color:#666;">
                ${c.last_sync_date ? new Date(c.last_sync_date).toLocaleDateString('fr-FR') : 'Jamais'}
            </td>
        </tr>
    `).join('');

    updateModalCount();
}

function filterModalTable(query) {
    const q = query.toLowerCase();
    renderModalTable(modal_computers.filter(c => c.name.toLowerCase().includes(q)));
}

function modalSelectAll()  { document.querySelectorAll('.modal_checkbox').forEach(c => c.checked = true);  updateModalCount(); }
function modalSelectNone() { document.querySelectorAll('.modal_checkbox').forEach(c => c.checked = false); updateModalCount(); }
function modalToggleAll(master) { document.querySelectorAll('.modal_checkbox').forEach(c => c.checked = master.checked); updateModalCount(); }

function updateModalCount() {
    const checked = document.querySelectorAll('.modal_checkbox:checked').length;
    const total   = document.querySelectorAll('.modal_checkbox').length;
    document.getElementById('modal_count').textContent = `${checked} / ${total} sélectionnée(s)`;
    updateQuotaBar(checked);
}

function updateQuotaBar(checked) {
    const container = document.getElementById('modal_quota_bar_container');
    const banner    = document.getElementById('modal_quota_banner');
    if (!container) return;

    if (!subscription_quota) {
        container.style.display = 'none';
        if (banner) banner.style.display = 'none';
        return;
    }

    container.style.display = 'block';

    const pct  = Math.min(100, Math.round((checked / subscription_quota) * 100));
    const rem  = subscription_quota - checked;
    const fill = document.getElementById('modal_quota_fill');
    document.getElementById('modal_quota_label').textContent     = `${checked} / ${subscription_quota} machines sélectionnées`;
    document.getElementById('modal_quota_remaining').textContent = rem > 0 ? `${rem} restante(s)` : 'Limite atteinte';

    fill.style.width = pct + '%';

    if (pct >= 100) {
        fill.style.background = '#dc3545';
        if (banner) banner.style.display = 'block';
        document.querySelectorAll('.modal_checkbox:not(:checked)').forEach(cb => {
            cb.disabled = true;
            cb.title    = 'Limite atteinte — désélectionnez d\'abord certaines machines';
        });
    } else {
        fill.style.background = pct >= 80 ? '#ffc107' : '#28a745';
        if (banner) banner.style.display = 'none';
        document.querySelectorAll('.modal_checkbox:not(:checked)').forEach(cb => {
            cb.disabled = false;
            cb.title    = '';
        });
    }
}

async function saveModalSelection() {
    const selected_ids = [...document.querySelectorAll('.modal_checkbox:checked')].map(c => parseInt(c.value));

    const resp = await fetch(`${WATCHMAN_SELECT_URL}?action=save_selection`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ selected_ids })
    });
    const data = await resp.json();

    if (data.success) {
        closeMachineModal();
        cms_watchman_load_computer_data();
        // notification
        const toast = document.createElement('div');
        toast.className = 'alert alert-success alert-dismissible fade show position-fixed';
        toast.style.cssText = 'top:20px; right:20px; z-index:99999; min-width:300px;';
        toast.innerHTML = `${data.message} <button type="button" class="btn-close" onclick="this.parentNode.remove()"></button>`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    }
}

async function removeMachine(computer_id) {
    const confirmed = await showRemovalWarning();
    if (!confirmed) return;

    const resp = await fetch(`${WATCHMAN_SELECT_URL}?action=get_all_computers`);
    const data = await resp.json();
    if (!data.success) return;

    const selected_ids = data.computers
        .filter(c => c.is_selected && c.id !== computer_id)
        .map(c => c.id);

    const resp2 = await fetch(`${WATCHMAN_SELECT_URL}?action=save_selection`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ selected_ids })
    });

    const data2 = await resp2.json();
    if (data2.success) loadSelectedMachines();
}

function showRemovalWarning() {
    return new Promise(resolve => {
        const overlay = document.createElement('div');
        overlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.55); z-index:99999; display:flex; align-items:center; justify-content:center;';
        overlay.innerHTML = `
            <div style="background:#fff; border-radius:12px; max-width:480px; width:90%; padding:28px; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
                <div style="display:flex; align-items:flex-start; gap:14px; margin-bottom:20px;">
                    <div style="background:#fff3cd; border-radius:50%; width:46px; height:46px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <i class="fas fa-exclamation-triangle" style="color:#e67e22; font-size:18px;"></i>
                    </div>
                    <div>
                        <h4 style="margin:0 0 8px 0; font-size:16px; font-weight:600;">Information de sécurité</h4>
                        <p style="margin:0; font-size:14px; color:#495057; line-height:1.6;">
                            Cette action retire la machine de la liste de synchronisation <strong>dans ce plugin uniquement</strong>.
                            La machine reste présente dans votre dashboard Watchman.
                        </p>
                        <p style="margin:10px 0 0 0; font-size:14px; color:#495057; line-height:1.6;">
                            Pour la supprimer définitivement, connectez-vous sur <strong>votre compte watchman.bj</strong>
                            et supprimez-la depuis votre dashboard. La suppression directe dans le plugin n'est pas
                            disponible pour des raisons de sécurité.
                        </p>
                    </div>
                </div>
                <div style="display:flex; justify-content:flex-end; gap:10px;">
                    <button id="warn_cancel" class="cms_watchman_btn cms_watchman_btn-outline">Annuler</button>
                    <button id="warn_confirm" class="cms_watchman_btn" style="background:#dc3545; color:#fff; border-color:#dc3545;">
                        Retirer du plugin
                    </button>
                </div>
            </div>
        `;
        document.body.appendChild(overlay);
        overlay.querySelector('#warn_cancel').onclick  = () => { overlay.remove(); resolve(false); };
        overlay.querySelector('#warn_confirm').onclick = () => { overlay.remove(); resolve(true); };
    });
}



// Configuration globale
const CMS_WATCHMAN_COMPUTER_CONFIG = {
    ajaxUrl: '{{ base_url }}/plugins/watchman/ajax/computer_mappings.php',
    csrfToken: '{{ csrf_token }}',
    baseUrl: '{{ base_url }}',
    translations: {
        confirmRemove: '{{ __("Êtes-vous sûr de vouloir retirer ce mapping ?", "watchman") }}',
        confirmBulkRemove: '{{ __("Êtes-vous sûr de vouloir retirer les mappings sélectionnés ?", "watchman") }}',
        confirmSync: '{{ __("Lancer la synchronisation de cet ordinateur ?", "watchman") }}',
        confirmBulkSync: '{{ __("Lancer la synchronisation des ordinateurs sélectionnés ?", "watchman") }}',
        loading: '{{ __("Chargement...", "watchman") }}',
        error: '{{ __("Erreur", "watchman") }}',
        success: '{{ __("Succès", "watchman") }}',
        noResults: '{{ __("Aucun résultat trouvé", "watchman") }}',
        loadingData: '{{ __("Chargement des données...", "watchman") }}',
        syncSuccess: '{{ __("Synchronisation lancée avec succès", "watchman") }}',
        syncError: '{{ __("Erreur lors de la synchronisation", "watchman") }}'
    }
};

// Variables globales
let cms_watchman_computers_data = [];
let cms_watchman_current_page = 1;
let cms_watchman_total_pages = 1;
let cms_watchman_filters = {
    search: '',
    status: '',
    date_from: '',
    date_to: ''
};

/**
 * Initialisation de la page
 */
document.addEventListener('DOMContentLoaded', function() {
    cms_watchman_init_computer_page();
});

/**
 * Initialise la page des ordinateurs
 */
function cms_watchman_init_computer_page() {
    // Masquer le loading et afficher le contenu principal
    document.querySelector('.cms_watchman_content_loading').style.display = 'none';
    document.querySelector('.cms_watchman_content_main_body').classList.remove('hidden');
    
    // Charger les données
    cms_watchman_load_computer_data();
    cms_watchman_load_computer_statistics();
    
    // Initialiser les événements
    cms_watchman_init_computer_events();
}

/**
 * Initialise les événements de la page
 */
function cms_watchman_init_computer_events() {
    // Bouton de synchronisation principale
    document.getElementById('cms_watchman_start_computer_sync_btn').addEventListener('click', function() {
        cms_watchman_start_computer_sync();
    });
    
    // Filtres - suppression du debounce sur les inputs pour utiliser le bouton de recherche
    document.getElementById('cms_watchman_search_computer_input_text').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            cms_watchman_apply_filters();
        }
    });
    document.getElementById('cms_watchman_search_computer_input_status').addEventListener('change', cms_watchman_apply_filters);
    
    // Boutons de recherche et reset
    document.getElementById('cms_watchman_search_computer_btn').addEventListener('click', cms_watchman_apply_filters);
    document.getElementById('cms_watchman_reset_search_computer_btn').addEventListener('click', cms_watchman_reset_filters);
    
    // Initialiser le date range picker
    cms_watchman_init_date_range_picker();
}

/**
 * Charge les données des ordinateurs
 */
async function cms_watchman_load_computer_data(page = 1) {
    try {
        const params = new URLSearchParams({
            action: 'get_computers',
            page: page,
            per_page: 20,
            ...cms_watchman_filters
        });
        
        const response = await fetch(`${CMS_WATCHMAN_COMPUTER_CONFIG.ajaxUrl}?${params}`, {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        if (!response.ok) {
            throw new Error('Erreur réseau');
        }

        //      for debug
        const text_response = await response.text();
        console.log('text', text_response);
        
        // Parser le JSON depuis le texte
        const data = JSON.parse(text_response);
        
        if (data.success) {
            cms_watchman_computers_data = data.data;
            cms_watchman_current_page = data.pagination.current_page;
            cms_watchman_total_pages = data.pagination.total_pages;
            
            cms_watchman_render_computers_table();
            cms_watchman_render_computers_pagination();
        } else {
            throw new Error(data.error || 'Erreur lors du chargement');
        }
        
    } catch (error) {
        console.error('Erreur:', error);
        cms_watchman_show_notification(error.message, 'error');
    }
}

/**
 * Charge les statistiques des ordinateurs
 */
async function cms_watchman_load_computer_statistics() {
    try {
        const response = await fetch(`${CMS_WATCHMAN_COMPUTER_CONFIG.ajaxUrl}?action=get_computer_stats`, {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        const data = await response.json();
        
        if (data.success) {
            document.getElementById('cms_watchman_computer_statistic_total_value').textContent = data.data.total || 0;
        }
        
    } catch (error) {
        console.error('Erreur statistiques:', error);
    }
}

/**
 * Rend le tableau des ordinateurs
 */
function cms_watchman_render_computers_table() {
    const tbody = document.getElementById('cms_watchman_computers_table_body');
    
    if (cms_watchman_computers_data.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="5" style="text-align: center; padding: 40px;">
                    <div class="cms_watchman_content_empty">
                        <h3>${CMS_WATCHMAN_COMPUTER_CONFIG.translations.noResults}</h3>
                    </div>
                </td>
            </tr>
        `;
        return;
    }
    
    tbody.innerHTML = cms_watchman_computers_data.map(computer => `
        <tr class="cms_watchman_computer_row" data-id="${computer.id}">
            <td>
                <div class="computer-name">
                    <strong>${computer.name || 'Computer #' + computer.id}</strong>
                    <br><small class="text-muted">ID GLPI: ${computer.computers_id || 'Non lié'}</small>
                    ${computer.external_id ? `<br><small class="text-info">External: ${computer.external_id}</small>` : ''}
                </div>
            </td>
            <td>
                ${cms_watchman_render_sync_status(computer)}
            </td>
            <td>
                ${computer.last_sync_date ? new Date(computer.last_sync_date).toLocaleDateString('fr-FR') + '<br><small>' + new Date(computer.last_sync_date).toLocaleTimeString('fr-FR', {hour: '2-digit', minute: '2-digit'}) + '</small>' : '<span class="text-muted">Jamais</span>'}
            </td>
            <td>
                ${computer.computers_id ? `<a href="${CMS_WATCHMAN_COMPUTER_CONFIG.baseUrl}/front/computer.form.php?id=${computer.computers_id}" class="cms_watchman_btn cms_watchman_btn-primary btn-sm" target="_blank"><i class="fas fa-desktop me-1"></i>GLPI</a>` : '<span class="text-muted">Non lié</span>'}
            </td>
            <td>
                ${cms_watchman_render_computer_actions(computer)}
            </td>
        </tr>
    `).join('');
}

/**
 * Rend le statut de synchronisation
 */
function cms_watchman_render_sync_status(computer) {
    const statusConfig = {
        'success': { class: 'success', label: 'Synchronisé', icon: 'check' },
        'synced': { class: 'success', label: 'Synchronisé', icon: 'check' },
        'pending': { class: 'warning', label: 'En attente', icon: 'clock' },
        'error': { class: 'danger', label: 'Erreur', icon: 'exclamation-triangle' },
        'failed': { class: 'danger', label: 'Échec', icon: 'times' }
    };
    
    const config = statusConfig[computer.sync_status] || statusConfig['pending'];
    let html = `<span class="cms_watchman_badge cms_watchman_badge-${config.class} sync-status-badge">
                    <i class="fas fa-${config.icon} me-1"></i>${config.label}
                </span>`;
    
    if ((computer.sync_status === 'error' || computer.sync_status === 'failed') && computer.error_message) {
        html += `<br><small class="text-danger" title="${computer.error_message}">
                    <i class="fas fa-exclamation-triangle"></i> ${computer.error_message.substring(0, 30)}...
                 </small>`;
    }
    
    return html;
}


/**
 * Rend les actions pour un ordinateur
 */
function cms_watchman_render_computer_actions(computer) {
    return `
        <a href="?computer_id=${computer.id}" class="cms_watchman_btn cms_watchman_btn-outline-primary btn-sm">
            <i class="fas fa-eye me-1"></i>Voir détails
        </a>
    `;
}

