<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
    
    :root {
        /* Palette de couleurs Watchman originale */
        --brand-10: rgba(0, 178, 149, 0.1);
        --brand-40: #b9d1cd;
        --brand-50: #80d9ca;
        --brand-100: #66d1bf;
        --brand-200: #4dc9b5;
        --brand-300: #33c1aa;
        --brand-400: #1abaa0;
        --brand-500: #00a086;
        --brand-600: #00b295;
        --brand-700: #008e77;
        --brand-800: #007d68;
        --brand-900: #006b59;
        
        /* Couleurs neutres */
        --neutral-50: #f8fafc;
        --neutral-100: #f1f5f9;
        --neutral-200: #e2e8f0;
        --neutral-300: #cbd5e1;
        --neutral-400: #94a3b8;
        --neutral-500: #64748b;
        --neutral-600: #475569;
        --neutral-700: #334155;
        --neutral-800: #1e293b;
        --neutral-900: #0f172a;
        
        --gradient-primary: linear-gradient(135deg, var(--brand-600) 0%, var(--brand-800) 100%);
        --shadow-lg: 0 25px 50px -12px rgba(0, 178, 149, 0.15);
    }

    .cms_watchman_content {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 4rem 2rem;
        text-align: center;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 50%, rgba(0, 178, 149, 0.02) 100%);
        color: var(--neutral-800);
        overflow: hidden;
    }

    /* Arrière-plan animé */
    .cms_watchman_content::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: 
            radial-gradient(circle at 25% 25%, rgba(0, 178, 149, 0.03) 0, transparent 50%),
            radial-gradient(circle at 75% 75%, rgba(0, 178, 149, 0.02) 0, transparent 50%),
            linear-gradient(rgba(0, 178, 149, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 178, 149, 0.05) 1px, transparent 1px);
        background-size: 100% 100%, 100% 100%, 60px 60px, 60px 60px;
        animation: grid-move 30s linear infinite;
        z-index: 0;
    }

    .cms_watchman_content > * {
        position: relative;
        z-index: 2;
    }

    .heading {
        font-size: clamp(2.5rem, 6vw, 3.5rem);
        font-weight: 700;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, var(--neutral-800) 0%, var(--brand-600) 50%, var(--brand-700) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: fade-in-up 0.8s ease-out;
        line-height: 1.2;
    }

    .cms_watchman_content img {
        height: 60px !important;
        margin-bottom: 2rem !important;
        animation: fade-in-up 0.8s ease-out 0.2s both;
        filter: drop-shadow(0 4px 8px rgba(0, 178, 149, 0.1));
    }

    .description {
        font-size: clamp(1rem, 2.5vw, 1.25rem);
        color: var(--neutral-600);
        max-width: 600px;
        margin: 0 auto 3rem;
        font-weight: 400;
        line-height: 1.6;
        animation: fade-in-up 0.8s ease-out 0.4s both;
    }

    .cms_watchman_flex {
        display: flex;
    }

    .cms_watchman_justify_center {
        justify-content: center;
    }

    .cms_watchman_items_center {
        align-items: center;
    }

    .cms_watchman_btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--gradient-primary);
        color: white;
        text-decoration: none;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 1.1rem;
        font-family: inherit;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-lg);
        border: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
        animation: fade-in-up 0.8s ease-out 0.6s both;
    }

    .cms_watchman_btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 35px 60px -12px rgba(0, 178, 149, 0.25);
        text-decoration: none;
        color: white;
    }

    .cms_watchman_btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: 0.5s;
    }

    .cms_watchman_btn:hover::before {
        left: 100%;
    }

    .cms_watchman_btn::after {
        content: '→';
        margin-left: 0.5rem;
        transition: transform 0.3s ease;
    }

    .cms_watchman_btn:hover::after {
        transform: translateX(4px);
    }

    /* Badge de statut */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(0, 178, 149, 0.12);
        border: 1px solid rgba(0, 178, 149, 0.25);
        border-radius: 50px;
        padding: 0.5rem 1rem;
        color: var(--brand-700);
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 2rem;
        animation: fade-in-up 0.8s ease-out;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background: var(--brand-500);
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    /* Particules flottantes */
    .floating-particles {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }

    .particle {
        position: absolute;
        width: 4px;
        height: 4px;
        background: var(--brand-400);
        border-radius: 50%;
        opacity: 0.2;
        animation: float-particle 12s infinite linear;
    }

    /* Animations */
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes grid-move {
        0% { transform: translate(0, 0); }
        100% { transform: translate(60px, 60px); }
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.7; transform: scale(1.1); }
    }

    @keyframes float-particle {
        0% {
            transform: translateY(100vh) translateX(0px);
            opacity: 0;
        }
        10% { opacity: 0.2; }
        90% { opacity: 0.2; }
        100% {
            transform: translateY(-10vh) translateX(50px);
            opacity: 0;
        }
    }

    /* Responsive */
    @media (max-width: 768px) {
        .cms_watchman_content {
            padding: 2rem 1rem;
            min-height: 80vh;
        }
        
        .description {
            font-size: 1rem;
            margin-bottom: 2rem;
        }
        
        .cms_watchman_btn {
            padding: 1rem 2rem;
            font-size: 1rem;
        }
    }

    @media (max-width: 480px) {
        .cms_watchman_content {
            padding: 1.5rem 1rem;
        }
        
        .cms_watchman_content img {
            height: 45px !important;
        }
        
        .cms_watchman_btn {
            width: 100%;
            max-width: 280px;
            justify-content: center;
        }
    }
</style>

<div class="cms_watchman_content container-fluid min-h-screen relative cms_watchman_welcom">
    <!-- Badge de statut -->
    <div class="status-badge">
        <div class="status-dot"></div>
        Surveillance Active
    </div>
    
    <!-- Contenu principal -->
    <h1 class="heading">Bienvenue sur</h1>
    <img src="{{ base_url }}/plugins/watchman/assets/images/cms_watchman/logo_watchman_light.png" alt="Logo Watchman" style="height: 60px; margin-bottom: 20px;"/>
    <p class="description">Nous veillons sur votre système d'information et vous informons des éventuelles failles de sécurité.</p>
    
    <div class="cms_watchman_flex cms_watchman_justify_center cms_watchman_items_center">
        <a class="cms_watchman_btn" href="?start={{csrf_token}}">Commencer</a>
    </div>
    
    <!-- Particules flottantes -->
    <div class="floating-particles"></div>
</div>

<script>
    // Création des particules flottantes
    function createWatchmanParticles() {
        const container = document.querySelector('.floating-particles');
        if (!container) return;
        
        const particleCount = 15;
        
        for (let i = 0; i < particleCount; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            
            // Position et timing aléatoires
            particle.style.left = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 12 + 's';
            particle.style.animationDuration = (Math.random() * 8 + 12) + 's';
            
            container.appendChild(particle);
        }
    }

    // Effet de parallaxe subtil au survol
    function initWatchmanParallax() {
        const content = document.querySelector('.cms_watchman_content');
        if (!content) return;
        
        content.addEventListener('mousemove', (e) => {
            const rect = content.getBoundingClientRect();
            const mouseX = (e.clientX - rect.left) / rect.width;
            const mouseY = (e.clientY - rect.top) / rect.height;
            
            const moveX = (mouseX - 0.5) * 10;
            const moveY = (mouseY - 0.5) * 10;
            
            const particles = content.querySelector('.floating-particles');
            if (particles) {
                particles.style.transform = `translate(${moveX}px, ${moveY}px)`;
            }
        });
    }

    // Effet de clic sur le bouton
    function initWatchmanButton() {
        const btn = document.querySelector('.cms_watchman_btn');
        if (!btn) return;
        
        btn.addEventListener('click', function(e) {
            // Créer un effet de ripple
            const ripple = document.createElement('span');
            const rect = this.getBoundingClientRect();
            const size = Math.max(rect.width, rect.height);
            const x = e.clientX - rect.left - size / 2;
            const y = e.clientY - rect.top - size / 2;
            
            ripple.style.cssText = `
                position: absolute;
                width: ${size}px;
                height: ${size}px;
                left: ${x}px;
                top: ${y}px;
                background: rgba(255, 255, 255, 0.3);
                border-radius: 50%;
                transform: scale(0);
                animation: ripple 0.6s linear;
                pointer-events: none;
            `;
            
            this.appendChild(ripple);
            
            setTimeout(() => {
                if (ripple.parentNode) {
                    ripple.parentNode.removeChild(ripple);
                }
            }, 600);
        });
    }

    // Animation ripple
    if (!document.getElementById('watchman-ripple-style')) {
        const style = document.createElement('style');
        style.id = 'watchman-ripple-style';
        style.textContent = `
            @keyframes ripple {
                to {
                    transform: scale(4);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);
    }

    // Initialisation quand le DOM est prêt
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            createWatchmanParticles();
            initWatchmanParallax();
            initWatchmanButton();
        });
    } else {
        createWatchmanParticles();
        initWatchmanParallax();
        initWatchmanButton();
    }
</script>