<style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');
        
        :root {
            --brand-10: rgba(0, 178, 149, 0.1);
            --brand-40: #b9d1cd;
            --brand-50: #80d9ca;
            --brand-100: #66d1bf;
            --brand-200: #4dc9b5;
            --brand-300: #33c1aa;
            --brand-400: #1abaa0;
            --brand-500: #00a086;
            --brand-600: #00b295;
            --brand-700: #008e77;
            --brand-800: #007d68;
            --brand-900: #006b59;
            --dark: #0f172a;
            --dark-light: #1e293b;
            --text: #e2e8f0;
            --text-light: #94a3b8;
        }
        
        
        .plugin-container {
            position: relative;
            width: 100%;
            height: 100vh;
            overflow: hidden;
            font-family: 'Space Grotesk', sans-serif;
            color: var(--text);
        }
        
        .background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }
        
        .stars {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(rgba(255, 255, 255, 0.8) 1px, transparent 1px);
            background-size: 30px 30px;
            opacity: 0.3;
            animation: twinkle 5s linear infinite;
        }
        
        .grid {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(0, 178, 149, 0.1) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 178, 149, 0.1) 1px, transparent 1px);
            background-size: 50px 50px;
            transform: rotate3d(1, 1, 1, 45deg);
            animation: grid-move 20s linear infinite;
        }
        
        .particles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }
        
        .particle {
            position: absolute;
            background: var(--brand-500);
            border-radius: 50%;
            opacity: 0;
            pointer-events: none;
        }
        
        .cms_watchman_content {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 2rem;
            text-align: center;
        }
        
        .heading {
            font-size: 4.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            background: linear-gradient(90deg, var(--text) 0%, var(--brand-400) 50%, var(--text) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: text-glow 3s ease-in-out infinite alternate;
            text-shadow: 0 0 20px rgba(0, 178, 149, 0.3);
        }
        
        .description {
            font-size: 1.2rem;
            color: var(--text-light);
            max-width: 600px;
            margin-bottom: 3rem;
            line-height: 1.6;
            opacity: 0;
            transform: translateY(20px);
            animation: fade-in 1s ease-out 0.5s forwards;
        }
        
        .cms_watchman_btn {
            display: inline-block;
            padding: 1rem 2.5rem;
            background: linear-gradient(90deg, var(--brand-400), var(--brand-600));
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1.1rem;
            box-shadow: 0 10px 30px rgba(0, 178, 149, 0.3);
            transition: all 0.3s ease;
            border: 1px solid rgba(0, 178, 149, 0.3);
            position: relative;
            overflow: hidden;
            opacity: 0;
            transform: translateY(20px);
            animation: fade-in 1s ease-out 1s forwards;
        }
        
        .cms_watchman_btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(0, 178, 149, 0.4);
            background: linear-gradient(90deg, var(--brand-600), var(--brand-400));
        }
        
        .cms_watchman_btn:after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: 0.5s;
        }
        
        .cms_watchman_btn:hover:after {
            left: 100%;
        }
        
        .scan-line {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--brand-400), transparent);
            opacity: 0.7;
            animation: scan 3s linear infinite;
            z-index: 1;
        }
        
        .cyber-border {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
            z-index: 1;
        }
        
        .cyber-border:before, .cyber-border:after {
            content: '';
            position: absolute;
            top: 2px;
            left: 2px;
            right: 2px;
            bottom: 2px;
            border: 2px solid var(--brand-400);
            border-radius: 15px;
            opacity: 0;
            animation: border-glow 2s ease-in-out infinite alternate;
        }
        
        .cyber-border:after {
            top: 4px;
            left: 4px;
            right: 4px;
            bottom: 4px;
            border-color: var(--brand-600);
            animation-delay: 0.5s;
        }
        
        .pulse-ring {
            position: absolute;
            width: 200px;
            height: 200px;
            border: 2px solid var(--brand-400);
            border-radius: 50%;
            opacity: 0;
            transform: scale(0);
            animation: pulse 3s ease-out infinite;
            z-index: 1;
        }
        
        .floating-elements {
            position: absolute;
            width: 100%;
            height: 100%;
            z-index: 1;
        }
        
        .floating-element {
            position: absolute;
            color: var(--brand-400);
            opacity: 0.1;
            animation: float 8s ease-in-out infinite;
            z-index: 1;
        }
        
        /* Animations */
        @keyframes twinkle {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.6; }
        }
        
        @keyframes grid-move {
            0% { transform: rotate3d(1, 1, 1, 45deg) translate(0, 0); }
            100% { transform: rotate3d(1, 1, 1, 45deg) translate(50px, 50px); }
        }
        
        @keyframes text-glow {
            0% { text-shadow: 0 0 10px rgba(0, 178, 149, 0.3); }
            100% { text-shadow: 0 0 30px rgba(0, 178, 149, 0.6), 0 0 60px rgba(0, 178, 149, 0.3); }
        }
        
        @keyframes fade-in {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @keyframes scan {
            0% { transform: translateY(0); }
            100% { transform: translateY(100vh); }
        }
        
        @keyframes border-glow {
            0% { opacity: 0.2; box-shadow: 0 0 5px var(--brand-400); }
            100% { opacity: 0.6; box-shadow: 0 0 20px var(--brand-400), 0 0 40px var(--brand-400); }
        }
        
        @keyframes pulse {
            0% {
                transform: scale(0);
                opacity: 0;
            }
            50% {
                opacity: 0.3;
            }
            100% {
                transform: scale(2);
                opacity: 0;
            }
        }
        
        @keyframes float {
            0% {
                transform: translateY(0) rotate(0deg);
                opacity: 0.1;
            }
            50% {
                transform: translateY(-20px) rotate(180deg);
                opacity: 0.3;
            }
            100% {
                transform: translateY(0) rotate(360deg);
                opacity: 0.1;
            }
        }
        
        @media (max-width: 768px) {
            .heading {
                font-size: 3rem;
            }
            
            .description {
                font-size: 1rem;
            }
        }
    </style>
    <div class="plugin-container">
        <div class="background">
            <div class="stars"></div>
            <div class="grid"></div>
            <div class="scan-line"></div>
            <div class="cyber-border"></div>
            <div class="particles"></div>
            <div class="floating-elements"></div>
        </div>
        
        <div class="cms_watchman_content container-fluid min-h-screen relative cms_watchman_welcom">
            <h1 class="heading">Watchman .</h1>
            <p class="description">Vos alertes de vulnérabilités issues de Watchman se transforment automatiquement en tickets prêts à l’action. Résultat : un suivi clair, une correction accélérée et une sécurité renforcée, sans effort supplémentaire.</p>
            <div class="cms_watchman_flex cms_watchman_justify_center cms_watchman_items_center">
                <a class="link" href="?start={{csrf_token}}">Commencer</a>
            </div>
        </div>
    </div>

    <script>
        // Create floating elements
        function createFloatingElements() {
            const container = document.querySelector('.floating-elements');
            const shapes = ['●', '■', '▲', '◆', '⬢', '⬡', '★', '✦'];
            
            for (let i = 0; i < 15; i++) {
                const element = document.createElement('div');
                element.className = 'floating-element';
                element.textContent = shapes[Math.floor(Math.random() * shapes.length)];
                element.style.fontSize = `${Math.random() * 20 + 10}px`;
                element.style.left = `${Math.random() * 100}%`;
                element.style.top = `${Math.random() * 100}%`;
                element.style.animationDelay = `${Math.random() * 5}s`;
                element.style.animationDuration = `${Math.random() * 10 + 5}s`;
                container.appendChild(element);
            }
        }
        
        // Create particles
        function createParticles() {
            const container = document.querySelector('.particles');
            const particleCount = 50;
            
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                
                const size = Math.random() * 5 + 1;
                const xPos = Math.random() * 100;
                const yPos = Math.random() * 100;
                const duration = Math.random() * 5 + 3;
                const delay = Math.random() * 5;
                
                particle.style.width = `${size}px`;
                particle.style.height = `${size}px`;
                particle.style.left = `${xPos}%`;
                particle.style.top = `${yPos}%`;
                particle.style.animation = `fade-in 1s ease-out ${delay}s forwards, float ${duration}s ease-in-out ${delay}s infinite`;
                
                // Add pulse effect
                setTimeout(() => {
                    particle.style.opacity = '0.7';
                    setTimeout(() => {
                        particle.style.opacity = '0';
                    }, 1000);
                }, delay * 1000);
                
                container.appendChild(particle);
            }
        }
        
        // Create pulse rings
        function createPulseRings() {
            const container = document.querySelector('.background');
            
            setInterval(() => {
                const ring = document.createElement('div');
                ring.className = 'pulse-ring';
                
                const xPos = Math.random() * 100;
                const yPos = Math.random() * 100;
                const delay = Math.random() * 3;
                
                ring.style.left = `${xPos}%`;
                ring.style.top = `${yPos}%`;
                ring.style.animationDelay = `${delay}s`;
                
                container.appendChild(ring);
                
                // Remove after animation completes
                setTimeout(() => {
                    if (ring.parentNode) {
                        ring.parentNode.removeChild(ring);
                    }
                }, 3000);
            }, 2000);
        }
        
        // Typing effect for heading
        function typingEffect() {
            const heading = document.querySelector('.heading');
            const originalText = heading.textContent;
            heading.textContent = '';
            
            let i = 0;
            const timer = setInterval(() => {
                if (i < originalText.length) {
                    heading.textContent += originalText.charAt(i);
                    i++;
                } else {
                    clearInterval(timer);
                }
            }, 100);
        }
        
        // Initialize animations
        document.addEventListener('DOMContentLoaded', () => {
            createFloatingElements();
            createParticles();
            createPulseRings();
            
            // Add slight delay before starting typing effect
            setTimeout(typingEffect, 500);
            
            // Add click effect to button
            const btn = document.querySelector('.cms_watchman_btn');
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                
                // Create ripple effect
                const ripple = document.createElement('span');
                const rect = this.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height);
                const x = e.clientX - rect.left - size / 2;
                const y = e.clientY - rect.top - size / 2;
                
                ripple.style.cssText = `
                    position: absolute;
                    width: ${size}px;
                    height: ${size}px;
                    left: ${x}px;
                    top: ${y}px;
                    background: rgba(255, 255, 255, 0.3);
                    border-radius: 50%;
                    transform: scale(0);
                    animation: ripple 0.6s linear;
                    pointer-events: none;
                `;
                
                this.appendChild(ripple);
                
                setTimeout(() => {
                    if (ripple.parentNode) {
                        ripple.parentNode.removeChild(ripple);
                    }
                }, 600);
            });
        });
        
        // Add ripple animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes ripple {
                to {
                    transform: scale(4);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);
    </script>
