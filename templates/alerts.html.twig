/**
 * Fonctions JavaScript pour l'interface Watchman
 * À remplacer dans le template Twig
 */

// Configuration globale
const WATCHMAN_CONFIG = {
    ajaxUrl: '{{ path('plugins/watchman/ajax/watchman.php') }}',
    csrfToken: '{{ csrf_token }}',
    translations: {
        confirmDelete: '{{ __("Êtes-vous sûr de vouloir supprimer cette alerte ?", "watchman") }}',
        confirmBulkDelete: '{{ __("Êtes-vous sûr de vouloir supprimer les alertes sélectionnées ?", "watchman") }}',
        confirmMarkPatched: '{{ __("Marquer cette alerte comme corrigée ?", "watchman") }}',
        confirmBulkPatched: '{{ __("Marquer les alertes sélectionnées comme corrigées ?", "watchman") }}',
        loading: '{{ __("Chargement...", "watchman") }}',
        error: '{{ __("Erreur", "watchman") }}',
        success: '{{ __("Succès", "watchman") }}'
    }
};

/**
 * Utilitaire pour les requêtes AJAX
 */
async function makeAjaxRequest(action, data = {}) {
    const payload = {
        action: action,
        _glpi_csrf_token: WATCHMAN_CONFIG.csrfToken,
        ...data
    };
    
    try {
        const response = await fetch(WATCHMAN_CONFIG.ajaxUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(payload)
        });
        

        
        const result = await response.json();
        console.log('response',result);
        
        if (!response.ok) {
            throw new Error(result.message || 'Erreur serveur');
        }
        
        return result;
    } catch (error) {
        console.error('Erreur AJAX:', error);
        throw error;
    }
}

/**
 * Affiche une notification toast
 */

function showNotification(message, type = 'info') {
    // Implémentation basique - peut être remplacée par une librairie toast
    const alertClass = {
        'success': 'alert-success',
        'error': 'alert-danger',
        'warning': 'alert-warning',
        'info': 'alert-info'
    }[type] || 'alert-info';
    
    const toast = document.createElement('div');
    toast.className = `alert ${alertClass} alert-dismissible fade show position-fixed`;
    toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    toast.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    
    document.body.appendChild(toast);
    
    // Auto-dismiss après 5 secondes
    setTimeout(() => {
        if (toast.parentNode) {
            toast.remove();
        }
    }, 5000);
}

/**
 * Démarre la synchronisation des alertes
 */
async function startCron() {
    const btn = event?.target;
    const originalText = btn?.innerHTML;
    
    try {
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>' + WATCHMAN_CONFIG.translations.loading;
        }
        
        const result = await makeAjaxRequest('start_cron');
        
        if (result.success) {
            showNotification(result.message, 'success');
            // Recharger la page après 2 secondes
            setTimeout(() => {
                location.reload();
            }, 2000);
        } else {
            showNotification(result.message, 'error');
        }
    } catch (error) {
        showNotification(error.message, 'error');
    } finally {
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    }
}

/**
 * Crée un ticket GLPI à partir d'une alerte
 */
async function createTicket(alertId, csrfToken) {
    const btn = event?.target;
    const originalText = btn?.innerHTML;
    
    try {
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>' + WATCHMAN_CONFIG.translations.loading;
        }
        
        const result = await makeAjaxRequest('create_ticket', {
            alert_id: alertId
        });
        
        if (result.success) {
            showNotification(result.message, 'success');
            
            // Mettre à jour l'interface : remplacer le bouton créer par un lien vers le ticket
            if (btn && result.ticket_id) {
                const newBtn = document.createElement('a');
                newBtn.href = `{{ path('front/ticket.form.php') }}?id=${result.ticket_id}`;
                newBtn.target = '_blank';
                newBtn.className = 'btn btn-sm btn-outline-primary';
                newBtn.innerHTML = `<i class="fas fa-ticket-alt me-1"></i>#${result.ticket_id}`;
                btn.parentNode.replaceChild(newBtn, btn);
            }
        } else {
            showNotification(result.message, 'error');
        }
    } catch (error) {
        showNotification(error.message, 'error');
    } finally {
        if (btn && btn.parentNode) {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    }
}

/**
 * Marque une alerte comme corrigée
 */
async function markAsPatched(alertId, csrfToken) {
    if (!confirm(WATCHMAN_CONFIG.translations.confirmMarkPatched)) {
        return;
    }
    
    try {
        const result = await makeAjaxRequest('mark_patched', {
            alert_id: alertId
        });

        console.log('Result:', result);
        
        if (result.success) {
            showNotification(result.message, 'success');
            
            // Mettre à jour visuellement la ligne
            const row = document.querySelector(`tr[data-alert-id="${alertId}"]`);
            if (row) {
                const statusCell = row.querySelector('td:nth-child(6)'); // Colonne statut
                if (statusCell) {
                    statusCell.innerHTML = `
                        <span class="badge bg-success">
                            <i class="fas fa-check me-1"></i>{{ __('Corrigée', 'watchman') }}
                        </span>
                        <small class="d-block text-muted">${new Date().toLocaleDateString('fr-FR')}</small>
                    `;
                }
                
                // Mettre à jour l'attribut data pour le filtrage
                row.setAttribute('data-patched', '1');
                
                // Supprimer l'option "Marquer comme corrigée" du menu
                const markPatchedLink = row.querySelector('a[onclick*="markAsPatched"]');
                if (markPatchedLink) {
                    markPatchedLink.parentElement.remove();
                }
            }
            
            // Mettre à jour les statistiques
            updateStatistics();
        } else {
            showNotification(result.message, 'error');
        }
    } catch (error) {
        showNotification(error.message, 'error');
    }
}

/**
 * Bascule le statut de faux positif d'une alerte
 */
async function toggleFalsePositive(alertId, isFalsePositive, csrfToken) {
    try {
        const result = await makeAjaxRequest('toggle_false_positive', {
            alert_id: alertId,
            is_false_positive: isFalsePositive
        });
        
        if (result.success) {
            showNotification(result.message, 'success');
            
            // Mettre à jour visuellement l'icône de faux positif
            const row = document.querySelector(`tr[data-alert-id="${alertId}"]`);
            if (row) {
                const cveCell = row.querySelector('td:nth-child(2)'); // Colonne CVE
                const falsePositiveIcon = cveCell?.querySelector('.fa-question-circle');
                
                if (isFalsePositive) {
                    if (!falsePositiveIcon) {
                        const icon = document.createElement('i');
                        icon.className = 'fas fa-question-circle text-warning ms-1';
                        icon.title = '{{ __("Possible faux positif", "watchman") }}';
                        cveCell?.appendChild(icon);
                    }
                } else {
                    if (falsePositiveIcon) {
                        falsePositiveIcon.remove();
                    }
                }
                
                // Mettre à jour le menu contextuel
                const toggleLink = row.querySelector('a[onclick*="toggleFalsePositive"]');
                if (toggleLink) {
                    const icon = toggleLink.querySelector('i');
                    const text = toggleLink.lastChild;
                    
                    if (isFalsePositive) {
                        icon.className = 'fas fa-undo me-2';
                        text.textContent = ' {{ __("Retirer faux positif", "watchman") }}';
                        toggleLink.setAttribute('onclick', `toggleFalsePositive('${alertId}', false, '${csrfToken}')`);
                    } else {
                        icon.className = 'fas fa-question-circle me-2';
                        text.textContent = ' {{ __("Marquer faux positif", "watchman") }}';
                        toggleLink.setAttribute('onclick', `toggleFalsePositive('${alertId}', true, '${csrfToken}')`);
                    }
                }
            }
        } else {
            showNotification(result.message, 'error');
        }
    } catch (error) {
        showNotification(error.message, 'error');
    }
}

/**
 * Supprime une alerte
 */
async function deleteAlert(alertId, csrfToken) {
    if (!confirm(WATCHMAN_CONFIG.translations.confirmDelete)) {
        return;
    }
    
    try {
        const result = await makeAjaxRequest('delete_alert', {
            alert_id: alertId
        });
        
        if (result.success) {
            showNotification(result.message, 'success');
            
            // Supprimer visuellement la ligne avec animation
            const row = document.querySelector(`tr[data-alert-id="${alertId}"]`);
            if (row) {
                row.style.transition = 'opacity 0.3s ease-out';
                row.style.opacity = '0';
                
                setTimeout(() => {
                    row.remove();
                    updateStatistics();
                    
                    // Vérifier s'il reste des alertes
                    const remainingRows = document.querySelectorAll('.alert-row');
                    if (remainingRows.length === 0) {
                        location.reload(); // Recharger pour afficher le message "Aucune alerte"
                    }
                }, 300);
            }
        } else {
            showNotification(result.message, 'error');
        }
    } catch (error) {
        showNotification(error.message, 'error');
    }
}

/**
 * Affiche les détails d'une alerte dans une modal
 */
async function viewAlert(alertId) {
    try {
        const result = await makeAjaxRequest('get_alert_details', {
            alert_id: alertId
        });
        
        if (result.success) {
            showAlertModal(result.alert, result.formatted);
        } else {
            showNotification(result.message, 'error');
        }
    } catch (error) {
        showNotification(error.message, 'error');
    }
}

/**
 * Affiche la modal avec les détails de l'alerte
 */
function showAlertModal(alert, formatted) {
    // Créer la modal si elle n'existe pas
