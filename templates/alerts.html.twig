                    </tr>
                </table>
            </div>
            <div class="col-md-6">
                <h6>{{ __('État des notifications', 'watchman') }}</h6>
                <div class="d-flex flex-column gap-2">
                    <div>
                        <i class="fas fa-${alert.integration_notified ? 'check text-success' : 'times text-muted'}"></i>
