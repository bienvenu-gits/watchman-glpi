                                `<span class="badge bg-${formatted.formatted_score.class}">${formatted.formatted_score.value}</span>` : 
                                '-'
                            }
                        </td>
                    </tr>
                    <tr>
                        <td><strong>{{ __('Sévérité', 'watchman') }}:</strong></td>
                        <td><span class="badge bg-${formatted.severity_class}">${formatted.severity_label}</span></td>
                    </tr>
                    <tr>
                        <td><strong>{{ __('Statut', 'watchman') }}:</strong></td>
                        <td><span class="badge bg-${formatted.status_class}">${formatted.status_label}</span></td>
                    </tr>
                    <tr>
                        <td><strong>{{ __('Date création', 'watchman') }}:</strong></td>
