{#
 # Template pour l'affichage de la liste des alertes
 # @var array alerts - Liste des alertes
 # @var object item - Instance de AlertManager
 # @var array params - Paramètres d'affichage
 # @var string csrf_token - Token CSRF
 #}

<div class="watchman-alerts-container">
    {# En-tête de la page #}
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">
            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
            {{ __('Alertes de sécurité', 'watchman') }}
            <span class="badge bg-secondary ms-2">{{ alerts|length }}</span>
        </h3>
        
        <div class="btn-group">
            <button type="button" class="btn btn-primary btn-sm" onclick="location.reload()">
                <i class="fas fa-sync me-1"></i>
                {{ __('Actualiser', 'watchman') }}
            </button>
            <button type="button" class="btn btn-success btn-sm" onclick="startCron()">
                <i class="fas fa-play me-1"></i>
                {{ __('Synchroniser', 'watchman') }}
            </button>
        </div>
    </div>

    {# Filtres et statistiques #}
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-8">
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm" id="severity-filter" onchange="filterAlerts()">
                        <option value="">{{ __('Toutes les sévérités', 'watchman') }}</option>
                        <option value="CRITICAL">{{ __('Critique', 'watchman') }}</option>
                        <option value="HIGH">{{ __('Élevée', 'watchman') }}</option>
                        <option value="MEDIUM">{{ __('Moyenne', 'watchman') }}</option>
                        <option value="LOW">{{ __('Faible', 'watchman') }}</option>
                    </select>
                    
                    <select class="form-select form-select-sm" id="patched-filter" onchange="filterAlerts()">
                        <option value="">{{ __('Tous les statuts', 'watchman') }}</option>
                        <option value="0">{{ __('Non corrigées', 'watchman') }}</option>
                        <option value="1">{{ __('Corrigées', 'watchman') }}</option>
                    </select>
                    
                    <input type="text" class="form-control form-control-sm" id="search-input" 
                           placeholder="{{ __('Rechercher...', 'watchman') }}" onkeyup="filterAlerts()">
                </div>
            </div>
            
            <div class="col-md-4 text-end">
                {% set critical_count = 0 %}
                {% set high_count = 0 %}
                {% set unpatched_count = 0 %}
                
                {% for alert in alerts %}
                    {% if alert.severity == 'CRITICAL' %}
                        {% set critical_count = critical_count + 1 %}
                    {% elseif alert.severity == 'HIGH' %}
                        {% set high_count = high_count + 1 %}
                    {% endif %}
                    
                    {% if alert.patched == 0 %}
                        {% set unpatched_count = unpatched_count + 1 %}
                    {% endif %}
                {% endfor %}
                
                <div class="d-flex gap-3 justify-content-end">
                    <div class="text-center">
                        <div class="badge bg-danger fs-6">{{ critical_count }}</div>
                        <small class="d-block text-muted">{{ __('Critique', 'watchman') }}</small>
                    </div>
                    <div class="text-center">
                        <div class="badge bg-warning fs-6">{{ high_count }}</div>
                        <small class="d-block text-muted">{{ __('Élevée', 'watchman') }}</small>
                    </div>
                    <div class="text-center">
                        <div class="badge bg-info fs-6">{{ unpatched_count }}</div>
                        <small class="d-block text-muted">{{ __('Non corrigées', 'watchman') }}</small>
                    </div>
                </div>
            </div>
        </div>

        {# Tableau des alertes #}
        {% if alerts|length > 0 %}
            <div class="table-responsive">
                <table class="table table-hover" id="alerts-table">
                    <thead class="table-light">
                        <tr>
                            <th width="5%">
                                <input type="checkbox" id="select-all" onchange="toggleAllAlerts()">
                            </th>
                            <th width="15%">{{ __('CVE', 'watchman') }}</th>
                            <th width="25%">{{ __('Titre', 'watchman') }}</th>
                            <th width="10%">{{ __('Score', 'watchman') }}</th>
                            <th width="10%">{{ __('Sévérité', 'watchman') }}</th>
                            <th width="10%">{{ __('Statut', 'watchman') }}</th>
                            <th width="10%">{{ __('Ticket', 'watchman') }}</th>
                            <th width="10%">{{ __('Date', 'watchman') }}</th>
                            <th width="5%">{{ __('Actions', 'watchman') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for alert in alerts %}
                            <tr class="alert-row" 
                                data-severity="{{ alert.severity|lower }}" 
                                data-patched="{{ alert.patched }}"
                                data-search="{{ (alert.title ~ ' ' ~ alert.cves_id ~ ' ' ~ alert.description)|lower }}">
                                <td>
                                    <input type="checkbox" class="alert-checkbox" value="{{ alert.id }}">
                                </td>
                                
                                <td>
                                    <code class="fw-bold text-primary">{{ alert.cves_id }}</code>
                                    {% if alert.possible_false %}
                                        <i class="fas fa-question-circle text-warning ms-1" 
                                           title="{{ __('Possible faux positif', 'watchman') }}"></i>
                                    {% endif %}
                                </td>
                                
                                <td>
                                    <div class="fw-bold">{{ alert.title|slice(0, 60) }}{% if alert.title|length > 60 %}...{% endif %}</div>
                                    <small class="text-muted">{{ alert.description|slice(0, 100)|striptags }}{% if alert.description|length > 100 %}...{% endif %}</small>
                                </td>
                                
                                <td class="text-center">
                                    {% if alert.score %}
                                        {% set score_class = 'success' %}
                                        {% if alert.score >= 7.0 %}
                                            {% set score_class = 'danger' %}
                                        {% elseif alert.score >= 4.0 %}
                                            {% set score_class = 'warning' %}
                                        {% endif %}
                                        <span class="badge bg-{{ score_class }}">{{ alert.score }}</span>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                
                                <td class="text-center">
                                    {% if alert.severity %}
                                        {% set severity_class = 'secondary' %}
                                        {% set severity_label = alert.severity %}
                                        
                                        {% if alert.severity == 'CRITICAL' %}
                                            {% set severity_class = 'danger' %}
                                            {% set severity_label = __('Critique', 'watchman') %}
                                        {% elseif alert.severity == 'HIGH' %}
                                            {% set severity_class = 'warning' %}
                                            {% set severity_label = __('Élevée', 'watchman') %}
                                        {% elseif alert.severity == 'MEDIUM' %}
                                            {% set severity_class = 'info' %}
                                            {% set severity_label = __('Moyenne', 'watchman') %}
                                        {% elseif alert.severity == 'LOW' %}
                                            {% set severity_class = 'success' %}
                                            {% set severity_label = __('Faible', 'watchman') %}
                                        {% endif %}
                                        
                                        <span class="badge bg-{{ severity_class }}">{{ severity_label }}</span>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                
                                <td class="text-center">
                                    <div class="d-flex flex-column gap-1">
                                        {% if alert.patched %}
                                            <span class="badge bg-success">
                                                <i class="fas fa-check me-1"></i>{{ __('Corrigée', 'watchman') }}
                                            </span>
                                            {% if alert.patched_at %}
                                                <small class="text-muted">{{ alert.patched_at|date('d/m/Y') }}</small>
                                            {% endif %}
                                        {% else %}
                                            <span class="badge bg-warning">
                                                <i class="fas fa-exclamation me-1"></i>{{ __('En attente', 'watchman') }}
                                            </span>
                                        {% endif %}
                                        
                                        {# <div class="d-flex gap-1 justify-content-center">
                                            {% if alert.integration_notified %}
                                                <i class="fas fa-bell text-success" title="{{ __('Intégration notifiée', 'watchman') }}"></i>
                                            {% endif %}
                                            {% if alert.email_notified %}
                                                <i class="fas fa-envelope text-primary" title="{{ __('Email envoyé', 'watchman') }}"></i>
                                            {% endif %}
                                            {% if alert.reported %}
                                                <i class="fas fa-flag text-info" title="{{ __('Signalée', 'watchman') }}"></i>
                                            {% endif %}
                                        </div> #}

                                    </div>
                                </td>
                                
                                <td class="text-center">
                                    {% if alert.tickets_id %}
                                        <a href="{{ path('front/ticket.form.php') }}?id={{ alert.tickets_id }}" 
                                           class="btn btn-sm btn-outline-primary" target="_blank">
                                            <i class="fas fa-ticket-alt me-1"></i>#{{ alert.tickets_id }}
                                        </a>
                                    {% else %}
                                        <button class="btn btn-sm btn-outline-success" 
                                                onclick="createTicket('{{ alert.id }}', '{{ csrf_token }}')">
                                            <i class="fas fa-plus me-1"></i>{{ __('Créer', 'watchman') }}
                                        </button>
                                    {% endif %}
                                </td>
                                
                                <td>
                                    <div class="text-center">
                                        <div>{{ alert.date_creation|date('d/m/Y') }}</div>
                                        <small class="text-muted">{{ alert.date_creation|date('H:i') }}</small>
                                    </div>
                                </td>
                                
                                <td class="text-center">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" 
                                                type="button" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <a class="dropdown-item" href="?alert_id={{alert.id}}" >
                                                    <i class="fas fa-eye me-2"></i>{{ __('Voir détails', 'watchman') }}
                                                </a>
                                            </li>
                                            {% if not alert.patched %}
                                                <li>
                                                    <a class="dropdown-item" href="#" onclick="markAsPatched('{{ alert.id }}', '{{ csrf_token }}')">
                                                        <i class="fas fa-check me-2"></i>{{ __('Marquer comme corrigée', 'watchman') }}
                                                    </a>
                                                </li>
                                            {% endif %}
                                            
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            {# Actions groupées #}
            <div class="mt-3 d-none" id="bulk-actions">
                <div class="alert alert-info">
                    <strong><span id="selected-count">0</span></strong> {{ __('alerte(s) sélectionnée(s)', 'watchman') }}
                    <div class="btn-group ms-3">
                        <button class="btn btn-success btn-sm" onclick="bulkAction('mark-patched')">
                            <i class="fas fa-check me-1"></i>{{ __('Marquer comme corrigées', 'watchman') }}
                        </button>
                        {# <button class="btn btn-warning btn-sm" onclick="bulkAction('false-positive')">
                            <i class="fas fa-question-circle me-1"></i>{{ __('Faux positifs', 'watchman') }}
                        </button> #}
                        <button class="btn btn-primary btn-sm" onclick="bulkAction('create-tickets')">
                            <i class="fas fa-ticket-alt me-1"></i>{{ __('Créer tickets', 'watchman') }}
                        </button>
                        {# <button class="btn btn-danger btn-sm" onclick="bulkAction('delete')">
                            <i class="fas fa-trash me-1"></i>{{ __('Supprimer', 'watchman') }}
                        </button> #}
                    </div>
                </div>
            </div>
            
        {% else %}
            {# Aucune alerte #}
            <div class="text-center py-5">
                <i class="fas fa-shield-alt text-success" style="font-size: 4rem;"></i>
                <h4 class="mt-3">{{ __('Aucune alerte active', 'watchman') }}</h4>
                <p class="text-muted">{{ __('Toutes vos applications semblent être à jour !', 'watchman') }}</p>
                <button class="btn btn-primary" onclick="startCron()">
                    <i class="fas fa-sync me-2"></i>{{ __('Vérifier maintenant', 'watchman') }}
                </button>
            </div>
        {% endif %}
    </div>
</div>

{# JavaScript pour les interactions #}
<script>
function filterAlerts() {
    const severityFilter = document.getElementById('severity-filter').value.toLowerCase();
    const patchedFilter = document.getElementById('patched-filter').value;
    const searchTerm = document.getElementById('search-input').value.toLowerCase();
    
    const rows = document.querySelectorAll('.alert-row');
    
    rows.forEach(row => {
        const severity = row.dataset.severity;
        const patched = row.dataset.patched;
        const searchData = row.dataset.search;
        
        let showRow = true;
        
        if (severityFilter && severity !== severityFilter) showRow = false;
        if (patchedFilter !== '' && patched !== patchedFilter) showRow = false;
        if (searchTerm && !searchData.includes(searchTerm)) showRow = false;
        
        row.style.display = showRow ? '' : 'none';
    });
}

function toggleAllAlerts() {
    const masterCheckbox = document.getElementById('select-all');
    const checkboxes = document.querySelectorAll('.alert-checkbox');
    
    checkboxes.forEach(cb => {
        cb.checked = masterCheckbox.checked;
    });
    
    updateBulkActions();
}

function updateBulkActions() {
    const checked = document.querySelectorAll('.alert-checkbox:checked');
    const bulkActions = document.getElementById('bulk-actions');
    const selectedCount = document.getElementById('selected-count');
    
    if (checked.length > 0) {
        bulkActions.classList.remove('d-none');
        selectedCount.textContent = checked.length;
    } else {
        bulkActions.classList.add('d-none');
    }
}

// Event listeners pour les checkboxes
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.alert-checkbox').forEach(cb => {
        cb.addEventListener('change', updateBulkActions);
    });
});

