/**
 * Crée la structure HTML de la modal
 */
function createAlertModal() {
    const modal = document.createElement('div');
    modal.id = 'alert-details-modal';
    modal.className = 'modal fade';
    modal.innerHTML = `
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-exclamation-triangle text-warning me-2"></i>
                        {{ __('Détails de l\'alerte', 'watchman') }}
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <!-- Contenu dynamique -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        {{ __('Fermer', 'watchman') }}
                    </button>
                </div>
            </div>
        </div>
    `;
    return modal;
}

/**
 * Gère les actions groupées
 */
async function bulkAction(action) {
    const selected = Array.from(document.querySelectorAll('.alert-checkbox:checked')).map(cb => cb.value);
    
    if (selected.length === 0) {
        showNotification('{{ __("Aucune alerte sélectionnée", "watchman") }}', 'warning');
        return;
    }
    
    // Confirmation pour certaines actions
    let confirmMessage = '';
    switch (action) {
        case 'delete':
            confirmMessage = WATCHMAN_CONFIG.translations.confirmBulkDelete;
            break;
        case 'mark-patched':
            confirmMessage = WATCHMAN_CONFIG.translations.confirmBulkPatched;
            break;
    }
    
    if (confirmMessage && !confirm(confirmMessage)) {
        return;
    }
    
    try {
        const result = await makeAjaxRequest('bulk_action', {
            bulk_action: action,
            alert_ids: selected
        });
        
        if (result.success) {
            showNotification(result.message, 'success');
            
            // Actions spécifiques selon le type
            switch (action) {
                case 'delete':
                    // Supprimer les lignes sélectionnées
                    selected.forEach(alertId => {
                        const row = document.querySelector(`tr[data-alert-id="${alertId}"]`);
                        if (row) row.remove();
                    });
                    break;
                    
                case 'mark-patched':
                    // Mettre à jour le statut des lignes
                    selected.forEach(alertId => {
                        const row = document.querySelector(`tr[data-alert-id="${alertId}"]`);
                        if (row) {
                            row.setAttribute('data-patched', '1');
                            const statusCell = row.querySelector('td:nth-child(6)');
                            if (statusCell) {
                                statusCell.innerHTML = `
                                    <span class="badge bg-success">
                                        <i class="fas fa-check me-1"></i>{{ __('Corrigée', 'watchman') }}
                                    </span>
                                `;
                            }
                        }
                    });
                    break;
                    
                case 'create-tickets':
                    if (result.results && result.results.success) {
                        // Mettre à jour les cellules tickets pour les créations réussies
                        result.results.success.forEach(item => {
                            const row = document.querySelector(`tr[data-alert-id="${item.alert_id}"]`);
                            if (row) {
                                const ticketCell = row.querySelector('td:nth-child(7)');
                                if (ticketCell) {
                                    ticketCell.innerHTML = `
                                        <a href="{{ path('front/ticket.form.php') }}?id=${item.ticket_id}" 
                                           class="btn btn-sm btn-outline-primary" target="_blank">
                                            <i class="fas fa-ticket-alt me-1"></i>#${item.ticket_id}
                                        </a>
                                    `;
                                }
                            }
                        });
                    }
                    break;
            }
            
            // Décocher toutes les cases et masquer les actions groupées
            document.getElementById('select-all').checked = false;
            document.querySelectorAll('.alert-checkbox').forEach(cb => cb.checked = false);
            updateBulkActions();
            updateStatistics();
            
        } else {
            showNotification(result.message, 'error');
        }
    } catch (error) {
        showNotification(error.message, 'error');
    }
}

/**
 * Met à jour les statistiques affichées
 */
function updateStatistics() {
    const rows = document.querySelectorAll('.alert-row');
    let criticalCount = 0;
    let highCount = 0;
    let unpatchedCount = 0;
    
    rows.forEach(row => {
        const severity = row.dataset.severity;
        const patched = row.dataset.patched;
        
        if (severity === 'critical') criticalCount++;
        if (severity === 'high') highCount++;
        if (patched === '0') unpatchedCount++;
    });
    
    // Mettre à jour les badges de statistiques
    const criticalBadge = document.querySelector('.badge.bg-danger.fs-6');
    const highBadge = document.querySelector('.badge.bg-warning.fs-6');
    const unpatchedBadge = document.querySelector('.badge.bg-info.fs-6');
    
    if (criticalBadge) criticalBadge.textContent = criticalCount;
    if (highBadge) highBadge.textContent = highCount;
    if (unpatchedBadge) unpatchedBadge.textContent = unpatchedCount;
    
    // Mettre à jour le badge du nombre total
    const totalBadge = document.querySelector('.card-title .badge.bg-secondary');
    if (totalBadge) totalBadge.textContent = rows.length;
}

/**
 * Initialisation au chargement de la page
 */
document.addEventListener('DOMContentLoaded', function() {
    // Event listeners pour les checkboxes
    document.querySelectorAll('.alert-checkbox').forEach(cb => {
        cb.addEventListener('change', updateBulkActions);
    });
    
    // Event listeners pour les liens de détails
    document.querySelectorAll('a[onclick*="viewAlert"]').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const alertId = this.getAttribute('onclick').match(/viewAlert\('(\d+)'\)/)[1];
            viewAlert(alertId);
        });
    });
    
    // Ajouter les attributs data-alert-id aux lignes (si pas déjà présents)
    document.querySelectorAll('.alert-row').forEach(row => {
        const checkbox = row.querySelector('.alert-checkbox');
        if (checkbox && !row.hasAttribute('data-alert-id')) {
            row.setAttribute('data-alert-id', checkbox.value);
        }
    });
    
    // Auto-refresh toutes les 5 minutes
    setInterval(() => {
        if (confirm('{{ __("Actualiser les alertes ?", "watchman") }}')) {
            location.reload();
        }
    }, 300000); // 5 minutes
});

/**
 * Fonctions existantes (filterAlerts, toggleAllAlerts, updateBulkActions)
 * Conservées du template original
 */
function filterAlerts() {
    const severityFilter = document.getElementById('severity-filter').value.toLowerCase();
    const patchedFilter = document.getElementById('patched-filter').value;
    const searchTerm = document.getElementById('search-input').value.toLowerCase();
    
    const rows = document.querySelectorAll('.alert-row');
    let visibleCount = 0;
    
    rows.forEach(row => {
        const severity = row.dataset.severity;
        const patched = row.dataset.patched;
        const searchData = row.dataset.search;
        
        let showRow = true;
        
        if (severityFilter && severity !== severityFilter) showRow = false;
        if (patchedFilter !== '' && patched !== patchedFilter) showRow = false;
        if (searchTerm && !searchData.includes(searchTerm)) showRow = false;
        
        row.style.display = showRow ? '' : 'none';
        if (showRow) visibleCount++;
    });
    
    // Mettre à jour le compteur d'alertes visibles
    const totalBadge = document.querySelector('.card-title .badge.bg-secondary');
    if (totalBadge) {
        totalBadge.textContent = visibleCount;
        totalBadge.title = `${visibleCount} alertes affichées sur ${rows.length} total`;
    }
}

function toggleAllAlerts() {
    const masterCheckbox = document.getElementById('select-all');
    const visibleCheckboxes = document.querySelectorAll('.alert-row:not([style*="display: none"]) .alert-checkbox');
    
    visibleCheckboxes.forEach(cb => {
        cb.checked = masterCheckbox.checked;
    });
    
    updateBulkActions();
}

function updateBulkActions() {
    const checked = document.querySelectorAll('.alert-checkbox:checked');
    const bulkActions = document.getElementById('bulk-actions');
    const selectedCount = document.getElementById('selected-count');
    
    if (checked.length > 0) {
        bulkActions.classList.remove('d-none');
        selectedCount.textContent = checked.length;
    } else {
        bulkActions.classList.add('d-none');
    }
    
    // Mettre à jour l'état de la case "tout sélectionner"
    const masterCheckbox = document.getElementById('select-all');
    const visibleCheckboxes = document.querySelectorAll('.alert-row:not([style*="display: none"]) .alert-checkbox');
    const checkedVisible = document.querySelectorAll('.alert-row:not([style*="display: none"]) .alert-checkbox:checked');
    
    if (visibleCheckboxes.length > 0) {
        masterCheckbox.indeterminate = checkedVisible.length > 0 && checkedVisible.length < visibleCheckboxes.length;
        masterCheckbox.checked = checkedVisible.length === visibleCheckboxes.length;
    }
}
</script>

